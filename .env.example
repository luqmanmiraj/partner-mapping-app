# Copy to .env and fill in real values (never commit .env).

# --- HubSpot OAuth ---
HUBSPOT_CLIENT_ID=your_hubspot_app_client_id
HUBSPOT_CLIENT_SECRET=your_hubspot_app_client_secret
HUBSPOT_REDIRECT_URI=http://localhost:8505/auth/hubspot/callback
HUBSPOT_OAUTH_SCOPES=oauth crm.objects.companies.read crm.lists.read crm.schemas.contacts.read crm.objects.contacts.read crm.schemas.companies.read
MOCK_SSO=false

# Optional: mint internal JWT after OAuth
HUBSPOT_MINT_URL=
HUBSPOT_COMPANY_ID=

# Local dev: use run_app.py so /auth/hubspot/callback redirects into Streamlit
PORT=8505
STREAMLIT_INTERNAL_PORT=8505

SSO_LOGIN_URL=https://app.hubspot.com/login
CREATE_ACCOUNT_URL=https://www.nexusautomotiveinternational.eu/
